{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react",
    "jsxFactory": "jsx.jsx",
    "jsxFragmentFactory": "jsx.jsxFragment",
    "declaration": true
  },
  "include": ["src"]
}
