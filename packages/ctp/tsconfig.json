{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "jsx": "react",
    "jsxFactory": "jsx.jsx",
    "jsxFragmentFactory": "jsx.jsxFragment",
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*", "contexts/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}