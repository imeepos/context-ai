{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDirs": ["./src", "./contexts"],
    "composite": true,
    "jsx": "react",
    "jsxFactory": "jsx.jsx",
    "jsxFragmentFactory": "jsx.jsxFragment",
    "lib": [
      "ES2022",
      "DOM"
    ]
  },
  "include": [
    "src/**/*",
    "contexts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}