{
  "name": "@context-ai/ctp-lite",
  "version": "0.1.0",
  "description": "Context Protocol Lite - Lightweight JSX-based context management for LLM agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "llm",
    "agent",
    "context",
    "jsx",
    "protocol",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0",
    "deno": ">=1.30.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.56.0",
    "@mariozechner/pi-ai": "^0.56.0"
  }
}