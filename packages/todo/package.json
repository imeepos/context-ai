{
  "name": "@context-ai/todo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npx tsc -b ../os/tsconfig.json --force && tsc && node -e \"const fs=require('node:fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('manifest.xml','dist/manifest.xml');\"",
    "start": "node dist/index.js",
    "install:app": "node dist/installTodoApp.js"
  },
  "dependencies": {
    "@context-ai/os": "*",
    "@context-ai/ctp": "*",
    "@context-ai/agent": "*",
    "@mariozechner/pi-agent-core": "^0.56.0",
    "@mariozechner/pi-ai": "^0.56.0",
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
